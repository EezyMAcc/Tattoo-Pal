# Secrets and runtime data — never commit these
.env
data/

# Local conversation exports / build logs (not source) — at the top level and in
# any subfolder (e.g. build_artifacts/Phase 2/<transcript>.txt, loop chunk logs)
build_artifacts/*.txt
build_artifacts/**/*.txt

# Local working notes / scratchpads (not source)
scratchpads/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenv / tooling caches
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
