# Copy this file to .env and fill in every value before running the stack.
# .env is git-ignored — never commit it.
# The hermetic test suite needs NONE of these; they are only for running the
# server live (locally or in the container).

# ── Instagram credentials ──────────────────────────────────────────────────────
# A long-lived Instagram Graph API access token for an app/user permitted to
# call the Business Discovery API.
IG_ACCESS_TOKEN=your-long-lived-access-token-here

# The numeric Instagram Business/Creator account id that owns the token.
IG_USER_ID=your-instagram-business-user-id-here

# ── Data directory ─────────────────────────────────────────────────────────────
# Where artists.json / inspiration.json / seen.json are stored.
# In Docker this must match the volume mount path in docker-compose.yml.
TATTOO_FEED_DATA_DIR=/app/data

# ── OAuth 2.1 resource-server config ──────────────────────────────────────────
# (see RESEARCH.md §§2-5 and https://auth0.com/blog/add-remote-mcp-server-chatgpt/)
# The server validates bearer tokens issued by an external IdP; it does not
# issue them.

# Issuer URL of your IdP (Auth0 / Stytch / WorkOS / Descope ...).
# Must exactly match the `iss` claim in access tokens (no trailing slash).
MCP_AUTH_ISSUER=https://your-idp-issuer.example.com

# JWKS endpoint used to verify JWT signatures.
MCP_AUTH_JWKS_URL=https://your-idp-issuer.example.com/.well-known/jwks.json

# Canonical public URL of THIS MCP server — the RFC 8707 audience binding.
# The IdP must issue tokens with this value in the `aud` claim.
# Set to your stable ngrok URL (update MCP_AUTH_AUDIENCE when the URL changes).
MCP_AUTH_AUDIENCE=https://your-public-mcp-url.ngrok-free.app

# Comma-separated scopes the access token must carry. Leave blank for none.
MCP_AUTH_REQUIRED_SCOPES=mcp:read

# ── ngrok TLS ingress ──────────────────────────────────────────────────────────
# Auth token from your ngrok account dashboard (https://dashboard.ngrok.com).
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# Optional: stable ngrok domain so the ChatGPT connector URL does not churn.
# Reserve one at https://dashboard.ngrok.com/domains, then uncomment and add
# --domain=${NGROK_DOMAIN} to the ngrok command in docker-compose.yml.
# NGROK_DOMAIN=your-stable-name.ngrok-free.app
