# Copy this file to `.env` and fill in your real values. `.env` is gitignored.
# The hermetic test suite needs NONE of these — they are only for running the
# server live (locally or in the container). Exact OAuth key names are finalised
# in Chunk 2 of the build; the placeholders below are the intended contract.

# --- Instagram (Business Discovery) -----------------------------------------
# A long-lived Instagram Graph API access token for an app/user permitted to
# call the Business Discovery API.
IG_ACCESS_TOKEN=your-long-lived-access-token-here
# The Instagram Business/Creator account id that owns the token and acts as the
# querying account.
IG_USER_ID=your-instagram-business-user-id-here

# --- Storage ----------------------------------------------------------------
# Where the JSON stores live. Optional; defaults to ./data.
TATTOO_FEED_DATA_DIR=/absolute/path/to/data

# --- Transport --------------------------------------------------------------
# stdio (default) or http. The remote/ChatGPT deployment uses http.
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- OAuth 2.1 resource-server (the identity provider you delegate to) -------
# The server validates bearer tokens issued by this external authorization
# server; it does not issue them. See RESEARCH.md §§2-5.
# Issuer URL of your IdP (Auth0 / Stytch / WorkOS / Descope ...).
MCP_OAUTH_ISSUER=https://your-idp-issuer.example.com
# JWKS endpoint used to verify token signatures (often <issuer>/.well-known/jwks.json).
MCP_OAUTH_JWKS_URL=https://your-idp-issuer.example.com/.well-known/jwks.json
# Canonical public URL of THIS MCP server — the audience tokens must be bound to
# (RFC 8707). Must match what ChatGPT is pointed at, e.g. https://<ngrok-host>/mcp
MCP_OAUTH_AUDIENCE=https://your-public-host/mcp
# Space-separated scopes required to call the tools.
MCP_OAUTH_REQUIRED_SCOPES=tattoo-feed:use

# --- ngrok ingress (docker-compose) -----------------------------------------
# Authtoken for the ngrok container that exposes the server publicly.
# Free account -> dashboard -> Your Authtoken.
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
